# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=saas_projects
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Backend ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production
SECRET_KEY=change-this-super-secret-key-in-production-min-32-chars!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ────────────────────────────────────────────────────────────────
# URL of the backend API (as seen from the browser, not inside Docker)
API_URL=http://localhost:8000

# ─── Ports ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
